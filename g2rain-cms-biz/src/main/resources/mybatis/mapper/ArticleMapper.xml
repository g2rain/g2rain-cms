    <!-- 定义可复用排序方向片段 -->
    <sql id="directionClause">
        <choose>
            <when test="item.direction == 'DESC'">DESC</when>
            <otherwise>ASC</otherwise>
        </choose>
    </sql>

    <!-- 可复用的动态排序 SQL 片段 -->
    <sql id="dynamicOrderBy">
        <trim prefix="ORDER BY" suffixOverrides=",">
            <foreach collection="safeSorts" item="item" separator=",">
                <choose>
                    <when test="item.column == 'id'">
                        id
                        <include refid="directionClause"/>
                    </when>
                    <when test="item.column == 'createTime'">
                        create_time
                        <include refid="directionClause"/>
                    </when>
                    <when test="item.column == 'updateTime'">
                        update_time
                        <include refid="directionClause"/>
                    </when>
                    <when test="item.column == 'organId'">
                        organ_id
                        <include refid="directionClause"/>
                    </when>
                    <when test="item.column == 'spaceId'">
                        space_id
                        <include refid="directionClause"/>
                    </when>
                    <when test="item.column == 'categoryId'">
                        category_id
                        <include refid="directionClause"/>
                    </when>
                    <when test="item.column == 'sourceApplicationId'">
                        source_application_id
                        <include refid="directionClause"/>
                    </when>
                    <when test="item.column == 'sourceTraceId'">
                        source_trace_id
                        <include refid="directionClause"/>
                    </when>
                    <when test="item.column == 'title'">
                        title
                        <include refid="directionClause"/>
                    </when>
                    <when test="item.column == 'summary'">
                        summary
                        <include refid="directionClause"/>
                    </when>
                    <when test="item.column == 'cover'">
                        cover
                        <include refid="directionClause"/>
                    </when>
                    <when test="item.column == 'contentType'">
                        content_type
                        <include refid="directionClause"/>
                    </when>
                    <when test="item.column == 'author'">
                        author
                        <include refid="directionClause"/>
                    </when>
                    <when test="item.column == 'status'">
                        status
                        <include refid="directionClause"/>
                    </when>
                    <when test="item.column == 'publishTime'">
                        publish_time
                        <include refid="directionClause"/>
                    </when>
                    <when test="item.column == 'content'">
                        content
                        <include refid="directionClause"/>
                    </when>
                </choose>
            </foreach>
        </trim>
    </sql>

    <!-- 插入单条记录 -->
    <insert id="insert" parameterType="com.g2rain.cms.dao.po.ArticlePo">
        INSERT INTO article (
        <!-- 主键字段（自增主键不包含在插入语句中） -->
        id,
        <!-- 基础字段 -->
        create_time, update_time,
        <!-- 业务字段 -->
        organ_id, space_id, category_id, source_application_id, source_trace_id, title, summary, cover, content_type, author, status, publish_time, content,
        <!-- deleteFlag字段（如果存在） -->
        delete_flag,
        <!-- version字段（如果存在） -->
        version
        ) VALUES (
        <!-- 主键值（自增主键不包含） -->
        #{id, jdbcType=BIGINT},
        <!-- 基础字段值 -->
        #{createTime, jdbcType=TIMESTAMP}, #{updateTime, jdbcType=TIMESTAMP},
        <!-- 业务字段值 -->
        #{organId, jdbcType=BIGINT}, #{spaceId, jdbcType=BIGINT}, #{categoryId, jdbcType=BIGINT}, #{sourceApplicationId, jdbcType=BIGINT}, #{sourceTraceId, jdbcType=VARCHAR}, #{title, jdbcType=VARCHAR}, #{summary, jdbcType=VARCHAR}, #{cover, jdbcType=VARCHAR}, #{contentType, jdbcType=VARCHAR}, #{author, jdbcType=VARCHAR}, #{status, jdbcType=VARCHAR}, #{publishTime, jdbcType=TIMESTAMP}, #{content, jdbcType=LONGVARCHAR},
        <!-- deleteFlag字段值（如果存在，设置默认值为0） -->
        0,
        <!-- version字段值（如果存在，设置默认值为0） -->
        0
        )
    </insert>

    <!-- 批量插入记录 -->
    <insert id="insertMultiple" parameterType="java.util.List">
        INSERT INTO article (
        <!-- 主键字段（自增主键不包含） -->
        id,
        <!-- 基础字段 -->
        create_time, update_time,
        <!-- 业务字段 -->
        organ_id, space_id, category_id, source_application_id, source_trace_id, title, summary, cover, content_type, author, status, publish_time, content,
        <!-- deleteFlag字段（如果存在） -->
        delete_flag,
        <!-- version字段（如果存在） -->
        version
        ) VALUES
        <foreach collection="list" item="item" separator=",">
            (
            <!-- 主键值（自增主键不包含） -->
            #{item.id, jdbcType=BIGINT},
            <!-- 基础字段值 -->
            #{item.createTime, jdbcType=TIMESTAMP}, #{item.updateTime, jdbcType=TIMESTAMP},
            <!-- 业务字段值 -->
