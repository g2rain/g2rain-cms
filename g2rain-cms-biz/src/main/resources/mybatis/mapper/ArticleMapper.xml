            <!-- deleteFlag字段值（如果存在，设置默认值为0） -->
            0,
            <!-- version字段值（如果存在，设置默认值为0） -->
            0
            )
        </foreach>
    </insert>

    <!-- 根据ID更新记录（包含基础字段和业务字段） -->
    <update id="update" parameterType="com.g2rain.cms.dao.po.ArticlePo">
        UPDATE article
        <set>
            <!-- 基础字段更新（排除version，version单独处理） -->
            <if test="updateTime != null">
                update_time = #{updateTime, jdbcType=TIMESTAMP},
            </if>
            <!-- 业务字段更新 -->
            <if test="organId != null">
                organ_id = #{organId, jdbcType=BIGINT},
            </if>
            <if test="spaceId != null">
                space_id = #{spaceId, jdbcType=BIGINT},
            </if>
            <if test="categoryId != null">
                category_id = #{categoryId, jdbcType=BIGINT},
            </if>
            <if test="sourceApplicationId != null">
                source_application_id = #{sourceApplicationId, jdbcType=BIGINT},
            </if>
            <if test="sourceTraceId != null">
                source_trace_id = #{sourceTraceId, jdbcType=VARCHAR},
            </if>
            <if test="title != null">
                title = #{title, jdbcType=VARCHAR},
            </if>
            <if test="summary != null">
                summary = #{summary, jdbcType=VARCHAR},
            </if>
            <if test="cover != null">
                cover = #{cover, jdbcType=VARCHAR},
            </if>
            <if test="contentType != null">
                content_type = #{contentType, jdbcType=VARCHAR},
            </if>
            <if test="author != null">
                author = #{author, jdbcType=VARCHAR},
            </if>
            <if test="status != null">
                status = #{status, jdbcType=VARCHAR},
            </if>
            <if test="publishTime != null">
                publish_time = #{publishTime, jdbcType=TIMESTAMP},
            </if>
            <if test="content != null">
                content = #{content, jdbcType=LONGVARCHAR},
            </if>
            <!-- version字段更新（如果存在，版本号自增） -->
            version = version + 1
        </set>
        WHERE id = #{id, jdbcType=BIGINT}
    </update>

    <!-- 根据ID和Version更新记录（乐观锁更新，包含基础字段和业务字段） -->
    <update id="updateByVersion" parameterType="com.g2rain.cms.dao.po.ArticlePo">
        UPDATE article
        <set>
            <!-- 基础字段更新（排除version，version单独处理） -->
            <if test="updateTime != null">
                update_time = #{updateTime, jdbcType=TIMESTAMP},
            </if>
            <!-- 业务字段更新 -->
            <if test="organId != null">
                organ_id = #{organId, jdbcType=BIGINT},
            </if>
            <if test="spaceId != null">
                space_id = #{spaceId, jdbcType=BIGINT},
            </if>
            <if test="categoryId != null">
                category_id = #{categoryId, jdbcType=BIGINT},
            </if>
            <if test="sourceApplicationId != null">
                source_application_id = #{sourceApplicationId, jdbcType=BIGINT},
            </if>
            <if test="sourceTraceId != null">
                source_trace_id = #{sourceTraceId, jdbcType=VARCHAR},
            </if>
            <if test="title != null">
                title = #{title, jdbcType=VARCHAR},
            </if>
            <if test="summary != null">
                summary = #{summary, jdbcType=VARCHAR},
            </if>
            <if test="cover != null">
                cover = #{cover, jdbcType=VARCHAR},
            </if>
            <if test="contentType != null">
                content_type = #{contentType, jdbcType=VARCHAR},
            </if>
            <if test="author != null">
                author = #{author, jdbcType=VARCHAR},
            </if>
            <if test="status != null">
                status = #{status, jdbcType=VARCHAR},
            </if>
            <if test="publishTime != null">
                publish_time = #{publishTime, jdbcType=TIMESTAMP},
            </if>
            <if test="content != null">
                content = #{content, jdbcType=LONGVARCHAR},
            </if>
            <!-- version字段更新（乐观锁版本号自增） -->
            version = version + 1
        </set>
        WHERE id = #{id, jdbcType=BIGINT}
        AND version = #{version, jdbcType=INTEGER}
    </update>

    <!-- 根据ID删除记录（逻辑删除：将delete_flag设置为true） -->
    <update id="delete" parameterType="Long">
        UPDATE article
        <set>
            delete_flag = 1, version = version + 1
        </set>
        WHERE id = #{id, jdbcType=BIGINT}
        <!-- 只删除未删除的记录 -->
        AND (delete_flag = 0 OR delete_flag IS NULL)
    </update>

    <!-- 根据ID查询记录（查询所有字段） -->
    <select id="selectById" parameterType="Long" resultMap="BaseResultMap">
        SELECT
        <!-- 主键字段 -->
        id,
        <!-- 基础字段 -->
        create_time, update_time,
        <!-- 业务字段 -->
        organ_id, space_id, category_id, source_application_id, source_trace_id, title, summary, cover, content_type, author, status, publish_time, content,
        <!-- deleteFlag字段（如果存在） -->
        delete_flag,
        <!-- version字段（如果存在） -->
        version
        FROM article
        WHERE id = #{id, jdbcType=BIGINT}
        <!-- 过滤已删除的记录 -->
        AND (delete_flag = 0 OR delete_flag IS NULL)
    </select>

    <!-- 根据SelectDto条件查询列表 -->
    <select id="selectList" parameterType="com.g2rain.cms.dto.ArticleSelectDto" resultMap="BaseResultMap">
        SELECT
        <!-- 主键字段 -->
        id,
        <!-- 基础字段 -->
        create_time, update_time,
        <!-- 业务字段 -->
        organ_id, space_id, category_id, source_application_id, source_trace_id, title, summary, cover, content_type, author, status, publish_time, content,
        <!-- deleteFlag字段（如果存在） -->
        delete_flag,
        <!-- version字段（如果存在） -->
        version
        FROM article
        <where>
            <!-- 主键筛选 -->
            <if test="id != null">
                AND id = #{id, jdbcType=BIGINT}
            </if>
            <if test="ids != null and ids.size() > 0">
                AND id IN
                <foreach collection="ids" item="item" open="(" separator="," close=")">
                    #{item, jdbcType=BIGINT}
                </foreach>
            </if>
            <!-- 基础字段筛选（createTime和updateTime时间筛选） -->
            <if test="createTime != null">
                <if test="createTime[0] != '' and (createTime.size() lt 2 or createTime[1] == '')">
                    AND create_time >= #{createTime[0], jdbcType=TIMESTAMP}
                </if>
                <if test="createTime.size() >= 2 and createTime[0] == '' and createTime[1] != ''">
                    AND create_time &lt;= #{createTime[1], jdbcType=TIMESTAMP}
                </if>
                <if test="createTime.size() >= 2 and createTime[0] != '' and createTime[1] != ''">
                    AND create_time BETWEEN #{createTime[0], jdbcType=TIMESTAMP}
                    AND #{createTime[1], jdbcType=TIMESTAMP}
                </if>
            </if>
            <if test="updateTime != null">
                <if test="updateTime[0] != '' and (updateTime.size() lt 2 or updateTime[1] == '')">
                    AND update_time >= #{updateTime[0], jdbcType=TIMESTAMP}
                </if>
                <if test="updateTime.size() >= 2 and updateTime[0] == '' and updateTime[1] != ''">
                    AND update_time &lt;= #{updateTime[1], jdbcType=TIMESTAMP}
                </if>
                <if test="updateTime.size() >= 2 and updateTime[0] != '' and updateTime[1] != ''">
                    AND update_time BETWEEN #{updateTime[0], jdbcType=TIMESTAMP}
                    AND #{updateTime[1], jdbcType=TIMESTAMP}
                </if>
            </if>
            <!-- 业务字段筛选 -->
            <if test="organId != null">
                AND organ_id = #{organId, jdbcType=BIGINT}
            </if>
            <if test="spaceId != null">
                AND space_id = #{spaceId, jdbcType=BIGINT}
            </if>
            <if test="categoryId != null">
                AND category_id = #{categoryId, jdbcType=BIGINT}
            </if>
            <if test="sourceApplicationId != null">
                AND source_application_id = #{sourceApplicationId, jdbcType=BIGINT}
            </if>
            <if test="sourceTraceId != null">
                AND source_trace_id = #{sourceTraceId, jdbcType=VARCHAR}
            </if>
            <if test="title != null">
                AND title = #{title, jdbcType=VARCHAR}
            </if>
            <if test="summary != null">
                AND summary = #{summary, jdbcType=VARCHAR}
            </if>
            <if test="cover != null">
                AND cover = #{cover, jdbcType=VARCHAR}
            </if>
            <if test="contentType != null">
                AND content_type = #{contentType, jdbcType=VARCHAR}
            </if>
            <if test="author != null">
                AND author = #{author, jdbcType=VARCHAR}
            </if>
            <if test="status != null">
                AND status = #{status, jdbcType=VARCHAR}
            </if>
            <if test="publishTime != null">
                AND publish_time = #{publishTime, jdbcType=TIMESTAMP}
            </if>
            <if test="content != null">
                AND content = #{content, jdbcType=LONGVARCHAR}
            </if>
            <!-- 过滤已删除的记录 -->
            AND (delete_flag = 0 OR delete_flag IS NULL)
        </where>
        <include refid="dynamicOrderBy"/>
    </select>
</mapper>
