<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
    "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.g2rain.cms.dao.WebSiteDao">
    <!-- 通用结果集映射（包含所有字段：主键+基础字段+业务字段） -->
    <resultMap id="BaseResultMap" type="com.g2rain.cms.dao.po.WebSitePo">
        <!-- 主键字段 -->
        <id column="id" property="id" jdbcType="BIGINT"/>
        <!-- 基础字段（createTime、updateTime） -->
        <result column="create_time" property="createTime" jdbcType="TIMESTAMP"/>
        <result column="update_time" property="updateTime" jdbcType="TIMESTAMP"/>
        <!-- 业务字段（其他自定义字段） -->
        <result column="organ_id" property="organId" jdbcType="BIGINT"/>
        <result column="site_name" property="siteName" jdbcType="VARCHAR"/>
        <result column="site_code" property="siteCode" jdbcType="VARCHAR"/>
        <result column="domain" property="domain" jdbcType="VARCHAR"/>
        <result column="description" property="description" jdbcType="VARCHAR"/>
        <result column="status" property="status" jdbcType="VARCHAR"/>
        <!-- deleteFlag字段（如果存在） -->
        <result column="delete_flag" property="deleteFlag" jdbcType="TINYINT"/>
        <!-- version字段（如果存在） -->
        <result column="version" property="version" jdbcType="INTEGER"/>
    </resultMap>

    <!-- 定义可复用排序方向片段 -->
    <sql id="directionClause">
        <choose>
            <when test="item.direction == 'DESC'">DESC</when>
            <otherwise>ASC</otherwise>
        </choose>
    </sql>

    <!-- 可复用的动态排序 SQL 片段 -->
    <sql id="dynamicOrderBy">
        <trim prefix="ORDER BY" suffixOverrides=",">
            <foreach collection="safeSorts" item="item" separator=",">
                <choose>
                    <when test="item.column == 'id'">
                        id
                        <include refid="directionClause"/>
                    </when>
                    <when test="item.column == 'createTime'">
                        create_time
                        <include refid="directionClause"/>
                    </when>
                    <when test="item.column == 'updateTime'">
                        update_time
                        <include refid="directionClause"/>
                    </when>
                    <when test="item.column == 'organId'">
                        organ_id
                        <include refid="directionClause"/>
                    </when>
                    <when test="item.column == 'siteName'">
                        site_name
                        <include refid="directionClause"/>
                    </when>
                    <when test="item.column == 'siteCode'">
                        site_code
                        <include refid="directionClause"/>
                    </when>
                    <when test="item.column == 'domain'">
                        domain
                        <include refid="directionClause"/>
                    </when>
                    <when test="item.column == 'description'">
                        description
                        <include refid="directionClause"/>
                    </when>
                    <when test="item.column == 'status'">
                        status
                        <include refid="directionClause"/>
                    </when>
                </choose>
            </foreach>
        </trim>
    </sql>

    <!-- 插入单条记录 -->
    <insert id="insert" parameterType="com.g2rain.cms.dao.po.WebSitePo">
        INSERT INTO web_site (
        <!-- 主键字段（自增主键不包含在插入语句中） -->
        id,
        <!-- 基础字段 -->
        create_time, update_time,
        <!-- 业务字段 -->
        organ_id, site_name, site_code, domain, description, status,
        <!-- deleteFlag字段（如果存在） -->
        delete_flag,
        <!-- version字段（如果存在） -->
        version
        ) VALUES (
        <!-- 主键值（自增主键不包含） -->
        #{id, jdbcType=BIGINT},
        <!-- 基础字段值 -->
        #{createTime, jdbcType=TIMESTAMP}, #{updateTime, jdbcType=TIMESTAMP},
        <!-- 业务字段值 -->
        #{organId, jdbcType=BIGINT}, #{siteName, jdbcType=VARCHAR}, #{siteCode, jdbcType=VARCHAR}, #{domain, jdbcType=VARCHAR}, #{description, jdbcType=VARCHAR}, #{status, jdbcType=VARCHAR},
        <!-- deleteFlag字段值（如果存在，设置默认值为0） -->
        0,
        <!-- version字段值（如果存在，设置默认值为0） -->
        0
        )
    </insert>

    <!-- 批量插入记录 -->
    <insert id="insertMultiple" parameterType="java.util.List">
        INSERT INTO web_site (
        <!-- 主键字段（自增主键不包含） -->
        id,
        <!-- 基础字段 -->
        create_time, update_time,
        <!-- 业务字段 -->
        organ_id, site_name, site_code, domain, description, status,
        <!-- deleteFlag字段（如果存在） -->
        delete_flag,
        <!-- version字段（如果存在） -->
        version
        ) VALUES
        <foreach collection="list" item="item" separator=",">
            (
            <!-- 主键值（自增主键不包含） -->
            #{item.id, jdbcType=BIGINT},
            <!-- 基础字段值 -->
            #{item.createTime, jdbcType=TIMESTAMP}, #{item.updateTime, jdbcType=TIMESTAMP},
            <!-- 业务字段值 -->
            #{item.organId, jdbcType=BIGINT}, #{item.siteName, jdbcType=VARCHAR}, #{item.siteCode, jdbcType=VARCHAR}, #{item.domain, jdbcType=VARCHAR}, #{item.description, jdbcType=VARCHAR}, #{item.status, jdbcType=VARCHAR},
            <!-- deleteFlag字段值（如果存在，设置默认值为0） -->
            0,
            <!-- version字段值（如果存在，设置默认值为0） -->
            0
            )
        </foreach>
    </insert>

    <!-- 根据ID更新记录（包含基础字段和业务字段） -->
    <update id="update" parameterType="com.g2rain.cms.dao.po.WebSitePo">
        UPDATE web_site
        <set>
            <!-- 基础字段更新（排除version，version单独处理） -->
            <if test="updateTime != null">
                update_time = #{updateTime, jdbcType=TIMESTAMP},
            </if>
            <!-- 业务字段更新 -->
            <if test="organId != null">
                organ_id = #{organId, jdbcType=BIGINT},
            </if>
            <if test="siteName != null">
                site_name = #{siteName, jdbcType=VARCHAR},
            </if>
            <if test="siteCode != null">
                site_code = #{siteCode, jdbcType=VARCHAR},
            </if>
            <if test="domain != null">
                domain = #{domain, jdbcType=VARCHAR},
            </if>
            <if test="description != null">
                description = #{description, jdbcType=VARCHAR},
            </if>
            <if test="status != null">
                status = #{status, jdbcType=VARCHAR},
            </if>
            <!-- version字段更新（如果存在，版本号自增） -->
            version = version + 1
        </set>
        WHERE id = #{id, jdbcType=BIGINT}
    </update>

    <!-- 根据ID和Version更新记录（乐观锁更新，包含基础字段和业务字段） -->
    <update id="updateByVersion" parameterType="com.g2rain.cms.dao.po.WebSitePo">
        UPDATE web_site
        <set>
            <!-- 基础字段更新（排除version，version单独处理） -->
            <if test="updateTime != null">
                update_time = #{updateTime, jdbcType=TIMESTAMP},
            </if>
            <!-- 业务字段更新 -->
            <if test="organId != null">
                organ_id = #{organId, jdbcType=BIGINT},
            </if>
            <if test="siteName != null">
                site_name = #{siteName, jdbcType=VARCHAR},
            </if>
            <if test="siteCode != null">
                site_code = #{siteCode, jdbcType=VARCHAR},
            </if>
            <if test="domain != null">
                domain = #{domain, jdbcType=VARCHAR},
            </if>
            <if test="description != null">
                description = #{description, jdbcType=VARCHAR},
            </if>
            <if test="status != null">
                status = #{status, jdbcType=VARCHAR},
            </if>
            <!-- version字段更新（乐观锁版本号自增） -->
            version = version + 1
        </set>
        WHERE id = #{id, jdbcType=BIGINT}
        AND version = #{version, jdbcType=INTEGER}
    </update>

    <!-- 根据ID删除记录（逻辑删除：将delete_flag设置为true） -->
    <update id="delete" parameterType="Long">
        UPDATE web_site
        <set>
            delete_flag = 1, version = version + 1
        </set>
        WHERE id = #{id, jdbcType=BIGINT}
        <!-- 只删除未删除的记录 -->
        AND (delete_flag = 0 OR delete_flag IS NULL)
    </update>

    <!-- 根据ID查询记录（查询所有字段） -->
    <select id="selectById" parameterType="Long" resultMap="BaseResultMap">
        SELECT
        <!-- 主键字段 -->
        id,
        <!-- 基础字段 -->
        create_time, update_time,
        <!-- 业务字段 -->
        organ_id, site_name, site_code, domain, description, status,
        <!-- deleteFlag字段（如果存在） -->
        delete_flag,
        <!-- version字段（如果存在） -->
        version
        FROM web_site
        WHERE id = #{id, jdbcType=BIGINT}
        <!-- 过滤已删除的记录 -->
        AND (delete_flag = 0 OR delete_flag IS NULL)
    </select>

    <!-- 根据SelectDto条件查询列表 -->
    <select id="selectList" parameterType="com.g2rain.cms.dto.WebSiteSelectDto" resultMap="BaseResultMap">
        SELECT
        <!-- 主键字段 -->
        id,
        <!-- 基础字段 -->
        create_time, update_time,
        <!-- 业务字段 -->
        organ_id, site_name, site_code, domain, description, status,
        <!-- deleteFlag字段（如果存在） -->
        delete_flag,
        <!-- version字段（如果存在） -->
        version
        FROM web_site
        <where>
            <!-- 主键筛选 -->
            <if test="id != null">
                AND id = #{id, jdbcType=BIGINT}
            </if>
            <if test="ids != null and ids.size() > 0">
                AND id IN
                <foreach collection="ids" item="item" open="(" separator="," close=")">
                    #{item, jdbcType=BIGINT}
                </foreach>
            </if>
            <!-- 基础字段筛选（createTime和updateTime时间筛选） -->
            <if test="createTime != null">
                <if test="createTime[0] != '' and (createTime.size() lt 2 or createTime[1] == '')">
                    AND create_time >= #{createTime[0], jdbcType=TIMESTAMP}
                </if>
                <if test="createTime.size() >= 2 and createTime[0] == '' and createTime[1] != ''">
                    AND create_time &lt;= #{createTime[1], jdbcType=TIMESTAMP}
                </if>
                <if test="createTime.size() >= 2 and createTime[0] != '' and createTime[1] != ''">
                    AND create_time BETWEEN #{createTime[0], jdbcType=TIMESTAMP}
                    AND #{createTime[1], jdbcType=TIMESTAMP}
                </if>
            </if>
            <if test="updateTime != null">
                <if test="updateTime[0] != '' and (updateTime.size() lt 2 or updateTime[1] == '')">
                    AND update_time >= #{updateTime[0], jdbcType=TIMESTAMP}
                </if>
                <if test="updateTime.size() >= 2 and updateTime[0] == '' and updateTime[1] != ''">
                    AND update_time &lt;= #{updateTime[1], jdbcType=TIMESTAMP}
                </if>
                <if test="updateTime.size() >= 2 and updateTime[0] != '' and updateTime[1] != ''">
                    AND update_time BETWEEN #{updateTime[0], jdbcType=TIMESTAMP}
                    AND #{updateTime[1], jdbcType=TIMESTAMP}
                </if>
            </if>
            <!-- 业务字段筛选 -->
            <if test="organId != null">
                AND organ_id = #{organId, jdbcType=BIGINT}
            </if>
            <if test="siteName != null">
                AND site_name = #{siteName, jdbcType=VARCHAR}
            </if>
            <if test="siteCode != null">
                AND site_code = #{siteCode, jdbcType=VARCHAR}
            </if>
            <if test="domain != null">
                AND domain = #{domain, jdbcType=VARCHAR}
            </if>
            <if test="description != null">
                AND description = #{description, jdbcType=VARCHAR}
            </if>
            <if test="status != null">
                AND status = #{status, jdbcType=VARCHAR}
            </if>
            <!-- 过滤已删除的记录 -->
            AND (delete_flag = 0 OR delete_flag IS NULL)
        </where>
        <include refid="dynamicOrderBy"/>
    </select>
</mapper>
